{
  "$id": "xtrader.schemas.strategy_profile.v0_3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "strategy_id",
    "version",
    "indicator_plan_by_tf",
    "regime_spec",
    "signal_spec",
    "risk_spec"
  ],
  "properties": {
    "schema_version": {
      "const": "xtrader.strategy_profile.v0.3"
    },
    "strategy_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "indicator_plan_by_tf": {
      "type": "object",
      "minProperties": 1,
      "patternProperties": {
        "^[0-9]+[smhdw]$": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/indicator_plan_item"
          }
        }
      },
      "additionalProperties": false
    },
    "regime_spec": {
      "$ref": "regime_spec.v0.3.schema.json"
    },
    "signal_spec": {
      "$ref": "signal_spec.v0.3.schema.json"
    },
    "risk_spec": {
      "$ref": "risk_spec.v0.3.schema.json"
    },
    "metadata": {
      "type": "object",
      "default": {},
      "additionalProperties": true
    }
  },
  "$defs": {
    "indicator_plan_item": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "instance_id",
        "family",
        "params"
      ],
      "properties": {
        "instance_id": {
          "type": "string",
          "minLength": 1
        },
        "family": {
          "type": "string",
          "minLength": 1
        },
        "params": {
          "type": "object"
        }
      }
    }
  }
}
