{
  "$id": "xtrader.schemas.signal_spec.v0_3",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "entry_rules",
    "exit_rules",
    "reason_code_map"
  ],
  "properties": {
    "entry_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "exit_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "hold_rules": {
      "type": "array",
      "default": [],
      "items": {
        "$ref": "#/$defs/rule"
      }
    },
    "cooldown_bars": {
      "type": "integer",
      "minimum": 0,
      "default": 0
    },
    "cooldown_scope": {
      "type": "string",
      "enum": [
        "symbol_action"
      ],
      "default": "symbol_action"
    },
    "reason_code_map": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      }
    },
    "entry_gate_spec": {
      "$ref": "#/$defs/entry_gate_spec"
    }
  },
  "$defs": {
    "state": {
      "type": "string",
      "pattern": "^[A-Z][A-Z0-9_]*$"
    },
    "score_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "min",
        "max",
        "min_inclusive",
        "max_inclusive"
      ],
      "properties": {
        "min": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -1.0,
          "maximum": 1.0
        },
        "max": {
          "type": [
            "number",
            "null"
          ],
          "minimum": -1.0,
          "maximum": 1.0
        },
        "min_inclusive": {
          "type": "boolean",
          "default": true
        },
        "max_inclusive": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "action",
        "priority_rank",
        "score_range"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "action": {
          "type": "string",
          "enum": [
            "ENTER_LONG",
            "ENTER_SHORT",
            "EXIT",
            "HOLD"
          ]
        },
        "priority_rank": {
          "type": "integer",
          "minimum": 1
        },
        "score_range": {
          "$ref": "#/$defs/score_range"
        },
        "state_allow": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state"
          },
          "uniqueItems": true
        },
        "state_deny": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/state"
          },
          "uniqueItems": true
        },
        "enabled": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "entry_gate_spec": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled",
        "gates"
      ],
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "gates": {
          "type": "array",
          "default": [],
          "items": {
            "$ref": "#/$defs/entry_gate"
          }
        }
      }
    },
    "entry_gate": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "side",
        "level",
        "mode",
        "conditions"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "side": {
          "type": "string",
          "enum": [
            "LONG",
            "SHORT"
          ]
        },
        "level": {
          "type": "string",
          "minLength": 1
        },
        "mode": {
          "type": "string",
          "enum": [
            "all_of",
            "n_of_m",
            "cross_tf"
          ]
        },
        "min_hit": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "conditions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/entry_gate_condition"
          }
        }
      }
    },
    "entry_gate_condition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "key"
      ],
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": false
        }
      }
    }
  }
}
